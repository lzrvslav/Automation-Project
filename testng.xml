<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Test-methodSuite" parallel="methods" thread-count="4">
    <groups>
        <run>
            <include name="smoke"/>
        </run>
    </groups>

    <test name="Web Page Tests">
        <classes>
            <class name="WebPageTest"/>
        </classes>
    </test>

    <test name="Order Processing Tests">
        <classes>
            <class name="OrderProcessingTest"/>
        </classes>
    </test>
</suite>
